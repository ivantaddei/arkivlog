{
  "name": "arkivlog",
  "version": "0.1.1",
  "description": "Inmutable audit logs on Arkiv — TypeScript SDK",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "keywords": [
    "arkiv",
    "audit",
    "logs",
    "audit-log",
    "blockchain",
    "immutable",
    "compliance"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Arkiv-Network/arkiv-puna-tech-hackathon"
  },
  "homepage": "https://github.com/Arkiv-Network/arkiv-puna-tech-hackathon",
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "dev": "tsup src/index.ts --format esm --dts --watch",
    "prepare": "pnpm build",
    "prepublishOnly": "pnpm build"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "typescript": "^5.6.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
