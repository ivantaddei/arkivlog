# Copy to .env and fill in. Demo runs on port 3200.

# Endpoint of the ArkivLog SaaS (the web app on port 3100).
ARKIVLOG_ENDPOINT=http://localhost:3100/api/logs

# API key issued by the SaaS. Get it from http://localhost:3100/dashboard
# after signing in with MetaMask. The key resolves server-side to YOUR wallet,
# which becomes the $owner of every audit event written from this app.
ARKIVLOG_API_KEY=ak_...

# Vertex AI credentials (service account, NOT a key file).
VERTEX_PROJECT_ID=
VERTEX_LOCATION=us-central1
VERTEX_CLIENT_EMAIL=
VERTEX_PRIVATE_KEY=

# Model to use. Default: gemini-2.5-flash
MODEL=gemini-2.5-flash
