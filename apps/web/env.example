# Copy to .env and fill in. Server runs on port 3100.

# Arkiv testnet (Braga) — service wallet used as $creator on every entity.
# Generate a fresh key and fund it at https://braga.hoodi.arkiv.network/faucet/
ARKIV_SERVICE_PRIVATE_KEY=0x

# Secret used to sign session JWTs. ANY long random string is fine for the demo.
# In production, use a 32+ byte secret from a secrets manager.
SESSION_SECRET=please-set-me-to-something-long-and-random

# Test fixture wallet — used ONLY by smoke/list scripts as a placeholder.
# Not part of the SaaS runtime. Any valid address works.
SCRIPTS_TEST_OWNER=0x
