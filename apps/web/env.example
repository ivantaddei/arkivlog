# Copy to .env and fill in. Server runs on port 3100.

# Arkiv testnet (Braga) — service wallet used as $creator on every entity.
# Generate a fresh key and fund it at https://braga.hoodi.arkiv.network/faucet/
ARKIV_SERVICE_PRIVATE_KEY=0x

# Secret used to sign session JWTs. ANY long random string is fine for the demo.
# In production, use a 32+ byte secret from a secrets manager.
SESSION_SECRET=please-set-me-to-something-long-and-random

# Test fixture wallet — used ONLY by smoke/list scripts as a placeholder.
# Not part of the SaaS runtime. Any valid address works.
SCRIPTS_TEST_OWNER=0x

# ──────────────────────────────────────────────────────────────────────
# DEMO MODE (only set in deployed envs like Vercel — leave OFF locally)
# ──────────────────────────────────────────────────────────────────────
# When enabled, the dashboard becomes a public read-only view of a single
# pre-baked wallet's audit trail. SIWE auth is bypassed and the keystore
# never touches the filesystem (Vercel has read-only disk).
#
# Local dev: leave NEXT_PUBLIC_DEMO_MODE unset and the full SIWE +
# keystore flow runs normally.
#
# To enable on Vercel, set all four:
#   NEXT_PUBLIC_DEMO_MODE=true
#   DEMO_OWNER_WALLET=0x...        # the wallet whose logs the demo shows
#   DEMO_API_KEY=ak_...            # API key the deployed apps/demo sends
#   DEMO_PROJECT_KEY=0x...         # Arkiv entity key of the Project entity
#   DEMO_PROJECT_NAME="ArkivLog Public Demo"   # optional, has a default
NEXT_PUBLIC_DEMO_MODE=
DEMO_OWNER_WALLET=
DEMO_API_KEY=
DEMO_PROJECT_KEY=
DEMO_PROJECT_NAME=
